rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Conversations collection
    match /conversations/{convId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Messages collection
    match /messages/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false; // Messages are immutable
      allow delete: if isAdmin();
    }

    // Folders collection
    match /folders/{folderId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Prompt Templates — public read, admin write
    match /promptTemplates/{templateId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Shared Conversations — public read
    match /sharedConversations/{shareId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // App Config
    match /appConfig/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
